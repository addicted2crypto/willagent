# ============================================================
# WillAgent Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Server ---
PORT=3100
NODE_ENV=development
LOG_LEVEL=debug

# --- Claude API (for high-complexity tasks) ---
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_BASE_URL=https://api.anthropic.com

# --- Local Model (Ollama / vLLM for low-complexity tasks) ---
LOCAL_MODEL_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.2
LOCAL_MODEL_MAX_TOKENS=2048

# --- Redis (state & memory layer) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Agent Defaults ---
AGENT_MAX_ITERATIONS=15
AGENT_DEFAULT_TIMEOUT=30000
AGENT_ENABLE_AUDIT_LOG=true

# --- Sandbox (Docker tool execution) ---
SANDBOX_IMAGE=willagent-sandbox:latest
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_NETWORK=none

# --- Security ---
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=30
CORS_ORIGINS=http://localhost:3000
